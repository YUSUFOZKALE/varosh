# Veritabani dosya yolu
DATABASE_URL=./varosh.db

# Auth cookie anahtari (zorunlu - guclu rastgele deger girin)
# Olusturmak icin: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Site URL (WhatsApp linkleri icin)
SITE_URL=http://localhost:3002

# WhatsApp Bot HTTP port
BOT_PORT=3003

# Port
PORT=3002
